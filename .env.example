# .env.example  —  COMMITTED to git as a template. Contains NO secrets.
#
# To set up: copy this file to a new file named ".env" (which is gitignored)
# and paste your real values. Only these two PUBLIC values belong here — they
# are safe to ship inside the app.
#
# Get them from your Supabase dashboard: Project Settings -> API
#   - Project URL        -> EXPO_PUBLIC_SUPABASE_URL
#   - anon public key    -> EXPO_PUBLIC_SUPABASE_ANON_KEY
#
# NEVER put the service_role key here or anywhere in the app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The deployed web domain where the doctor's /clinic page lives. The "Share with
# a doctor" QR encodes <this>/clinic?token=... On web the app falls back to the
# current browser origin, so set this for native builds / to be explicit.
EXPO_PUBLIC_CLINIC_BASE_URL=https://your-clinic-web-domain
